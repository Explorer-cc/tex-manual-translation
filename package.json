{
  "name": "tex-manual-translation",
  "version": "1.3.0",
  "description": "Installable Claude and Codex skill for translating English LaTeX documentation into Chinese.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tex-manual-translation": "bin/tex-manual-translation.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node scripts/validate.mjs && python scripts/test_scripts.py",
    "validate": "node scripts/validate.mjs",
    "doctor": "node bin/tex-manual-translation.mjs doctor"
  },
  "keywords": [
    "claude",
    "codex",
    "omp",
    "skill",
    "latex",
    "translation",
    "chinese"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "omp": {
    "version": "1.3.0"
  }
}
